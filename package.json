{
  "name": "meu-desafio-bun",
  "type": "module",
  "version": "1.0.50",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "bun --watch src/server.ts",
    "start": "bun src/server.ts",
    "auth:generate": "better-auth generate --config src/lib/auth.ts --yes",
